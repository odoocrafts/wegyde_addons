<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="acca_registration.ListButtons" t-inherit="web.ListView.Buttons" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('o_list_buttons')]" position="inside">
            <button type="button" class="btn btn-secondary ms-1" t-on-click="onClickCopyUrl">
                <i class="fa fa-link"/> Copy Form URL
            </button>
        </xpath>
    </t>
</templates>
